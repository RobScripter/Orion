						if not CheckKey(BlacklistedKeys, Input.KeyCode) then
							BindValue = Input.KeyCode
							BindObj.Value = Input.KeyCode
							BindLabel.Text = tostring(Input.KeyCode):gsub("Enum.KeyCode.", "")
							Connection:Disconnect()
							if BindConfig.Flag and BindConfig.Save then
								local CfgData = {}
								for i,v in pairs(OrionLib.Flags) do
									if v.Save then
										if v.Type == "Colorpicker" then
											CfgData[i] = PackColor(v.Value)
										else
											CfgData[i] = v.Value
										end
