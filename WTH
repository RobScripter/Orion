				local function UpdateSlider(NewValue)
					NewValue = math.clamp(NewValue, SliderConfig.Min, SliderConfig.Max)
					local Incremented = math.floor((NewValue - SliderConfig.Min) / SliderConfig.Increment) * SliderConfig.Increment + SliderConfig.Min
					SliderValue = Incremented
					SliderObj.Value = Incremented
					local Scale = (Incremented - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min)
					SliderDrag.Size = UDim2.fromScale(Scale, 1)
					ValueLabel.Text = tostring(Incremented) .. " " .. SliderConfig.ValueName
					SliderConfig.Callback(Incremented)
					if SliderConfig.Save and SliderConfig.Flag then
						local CfgData = {}
						for i,v in pairs(OrionLib.Flags) do
							if v.Save then
								if v.Type == "Colorpicker" then
									CfgData[i] = PackColor(v.Value)
								else
									CfgData[i] = v.Value
								end
							end	
						end
						pcall(function()
							if OrionLib.Folder then
								writefile(OrionLib.Folder .. "/" .. game.GameId .. ".txt", HttpService:JSONEncode(CfgData))
							end
						end)
					end
				end
				
				function SliderObj:Set(NewValue)
					UpdateSlider(NewValue)
				end
				
				local Dragging = false
				AddConnection(SliderButton.InputBegan, function(Input)
					if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
						Dragging = true
					end
				end)
				
				AddConnection(UserInputService.InputEnded, function(Input)
					if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
						Dragging = false
					end
				end)
				
				AddConnection(UserInputService.InputChanged, function(Input)
					if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
						local MousePos = Mouse.X
						local ButtonPos = SliderButton.AbsolutePosition.X
						local ButtonSize = SliderButton.AbsoluteSize.X
						local Ratio = math.clamp((MousePos - ButtonPos) / ButtonSize, 0, 1)
						local NewValue = SliderConfig.Min + (Ratio * (SliderConfig.Max - SliderConfig.Min))
						UpdateSlider(NewValue)
					end
				end)
				
				UpdateSlider(SliderConfig.Default)
				AnimateSliderIntro(SliderDrag, SliderConfig.Default, SliderConfig.Min, SliderConfig.Max)
				return SliderObj
			end
			
