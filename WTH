						if BindConfig.Hold then
							BindConfig.Callback()
						else
							BindConfig.Callback()
						end
					end
				end)
				
				function BindObj:Set(NewKeyCode)
					BindValue = NewKeyCode
					BindObj.Value = NewKeyCode
					BindLabel.Text = tostring(NewKeyCode):gsub("Enum.KeyCode.", "")
				end
				
