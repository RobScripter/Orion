function OrionLib:MakeWindow(WindowConfig)
	local FirstTab = true
	local Minimized = false
	local Loaded = false
	local UIHidden = false

	-- ================================================================
	-- SYSTEME D'ANIMATION MEGA — avec queue pendant le loading
	-- ================================================================
	local _introIndex = 0
	local _isLoading = false
	local _animQueue = {} -- queue d'animations a jouer apres le loading
	local _lastElementTime = 0 -- timestamp du dernier element cree
	local _loadOverlay = nil -- reference a l'overlay pour le detruire apres
	local _loadTransitionOut = nil -- fonction pour lancer la transition out
	local _glitchCharsAnim = {"#","@","!","$","%","&","?","*","/","=","-","+","~","^","<",">","|","\\",":","[","]"}

	-- Fonction qui joue l'animation d'un element (appelee directement OU depuis la queue)
	local function _PlayElementAnim(frame, elementType, index)
		local delay = index * 0.04

		local origTransparency = frame.BackgroundTransparency
		local origSize = frame.Size
		local origClips = frame.ClipsDescendants

		frame.BackgroundTransparency = 1
		frame.ClipsDescendants = true
		frame.Size = UDim2.new(origSize.X.Scale, origSize.X.Offset, 0, 0)

		local hiddenDescs = {}
		local textDescs = {}
		for _, desc in next, frame:GetDescendants() do
			if desc:IsA("TextLabel") or desc:IsA("TextBox") then
				table.insert(hiddenDescs, {obj = desc, prop = "TextTransparency", orig = desc.TextTransparency})
				table.insert(textDescs, {obj = desc, origText = desc.Text})
				desc.TextTransparency = 1
			elseif desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
				table.insert(hiddenDescs, {obj = desc, prop = "ImageTransparency", orig = desc.ImageTransparency})
				desc.ImageTransparency = 1
			elseif desc:IsA("UIStroke") then
				table.insert(hiddenDescs, {obj = desc, prop = "Transparency", orig = desc.Transparency})
				desc.Transparency = 1
			end
		end

		task.spawn(function()
			task.wait(delay)

			-- Phase 1: Grow avec elastic bounce
			TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = origSize,
				BackgroundTransparency = origTransparency
			}):Play()

			-- Flash de couleur
			task.spawn(function()
				local origBG = frame.BackgroundColor3
				frame.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
				task.wait(0.08)
				TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					BackgroundColor3 = origBG
				}):Play()
			end)

			task.wait(0.08)

			-- Phase 2: Reveal enfants
			for _, info in next, hiddenDescs do
				TweenService:Create(info.obj, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					[info.prop] = info.orig
				}):Play()
			end

			-- Phase 3: Glitch texte
			if #textDescs > 0 then
				task.spawn(function()
					for _ = 1, 3 do
						for _, td in next, textDescs do
							if td.obj and td.obj.Parent then
								local glitched = ""
								for c = 1, math.min(#td.origText, 30) do
									if math.random() < 0.4 then
										glitched = glitched .. _glitchCharsAnim[math.random(1, #_glitchCharsAnim)]
									else
										glitched = glitched .. string.sub(td.origText, c, c)
									end
								end
								td.obj.Text = glitched
							end
						end
						task.wait(0.03)
					end
					for _, td in next, textDescs do
						if td.obj and td.obj.Parent then
							td.obj.Text = td.origText
						end
					end
				end)
			end

			-- Phase 4: Glow sweep
			task.spawn(function()
				local sweep = Instance.new("Frame")
				sweep.Size = UDim2.new(0, 3, 1, 0)
				sweep.Position = UDim2.new(0, 0, 0, 0)
				sweep.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				sweep.BackgroundTransparency = 0.7
				sweep.BorderSizePixel = 0
				sweep.ZIndex = frame.ZIndex + 5
				sweep.Parent = frame
				TweenService:Create(sweep, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Position = UDim2.new(1, 0, 0, 0),
					BackgroundTransparency = 1
				}):Play()
				task.wait(0.35)
				sweep:Destroy()
			end)


			task.wait(0.35)
			frame.ClipsDescendants = origClips
		end)
	end

	local function _PlayTabAnim(tabFrame, isFirst, index)
		local delay = index * 0.06

		local origSize = tabFrame.Size
		tabFrame.Size = UDim2.new(origSize.X.Scale, origSize.X.Offset, 0, 0)
		tabFrame.ClipsDescendants = true
		tabFrame.Title.TextTransparency = 1
		tabFrame.Ico.ImageTransparency = 1

		task.spawn(function()
			task.wait(delay)

			TweenService:Create(tabFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = origSize
			}):Play()

			task.wait(0.06)

			-- Icon pop pulse
			TweenService:Create(tabFrame.Ico, TweenInfo.new(0.15, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				ImageTransparency = isFirst and 0 or 0.4,
				Size = UDim2.new(0, 22, 0, 22)
			}):Play()
			task.wait(0.15)
			TweenService:Create(tabFrame.Ico, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, 18, 0, 18)
			}):Play()

			-- Glitch reveal texte
			local finalText = tabFrame.Title.Text
			local targetTransp = isFirst and 0 or 0.4
			TweenService:Create(tabFrame.Title, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				TextTransparency = targetTransp
			}):Play()
			task.spawn(function()
				for _ = 1, 3 do
					local g = ""
					for c = 1, #finalText do
						if math.random() < 0.4 then
							g = g .. _glitchCharsAnim[math.random(1, #_glitchCharsAnim)]
						else
							g = g .. string.sub(finalText, c, c)
						end
					end
					tabFrame.Title.Text = g
					task.wait(0.03)
				end
				tabFrame.Title.Text = finalText
			end)

			-- Highlight flash
			task.spawn(function()
				local highlight = Instance.new("Frame")
				highlight.Size = UDim2.new(1, 0, 1, 0)
				highlight.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				highlight.BackgroundTransparency = 0.9
				highlight.BorderSizePixel = 0
				highlight.ZIndex = tabFrame.ZIndex + 3
				highlight.Parent = tabFrame
				Instance.new("UICorner", highlight).CornerRadius = UDim.new(0, 5)
				TweenService:Create(highlight, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1
				}):Play()
				task.wait(0.35)
				highlight:Destroy()
			end)

			-- Side accent line
			task.spawn(function()
				local accent = Instance.new("Frame")
				accent.Size = UDim2.new(0, 2, 0, 0)
				accent.Position = UDim2.new(0, 0, 0.15, 0)
				accent.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
				accent.BackgroundTransparency = 0.3
				accent.BorderSizePixel = 0
				accent.ZIndex = tabFrame.ZIndex + 3
				accent.Parent = tabFrame
				TweenService:Create(accent, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Size = UDim2.new(0, 2, 0.7, 0)
				}):Play()
				task.wait(0.25)
				TweenService:Create(accent, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1
				}):Play()
				task.wait(0.35)
				accent:Destroy()
			end)

			task.wait(0.3)
			tabFrame.ClipsDescendants = false
		end)
	end

	local function _PlayToggleAnim(toggleBox, index)
		local savedSize = toggleBox.Size
		toggleBox.Size = UDim2.new(0, 0, 0, 0)
		toggleBox.Rotation = -90
		local delay = index * 0.04
		task.spawn(function()
			task.wait(delay + 0.1)
			TweenService:Create(toggleBox, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = savedSize,
				Rotation = 0
			}):Play()
			task.wait(0.35)
			task.spawn(function()
				local glow = Instance.new("UIStroke")
				glow.Color = Color3.fromRGB(100, 180, 255)
				glow.Transparency = 0.4
				glow.Thickness = 2
				glow.Parent = toggleBox
				TweenService:Create(glow, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Transparency = 1,
					Thickness = 0
				}):Play()
				task.wait(0.35)
				glow:Destroy()
			end)
		end)
	end

	local function _PlaySliderAnim(sliderDrag, sliderValue, sliderMin, sliderMax, index)
		sliderDrag.Size = UDim2.new(0, 0, 1, 0)
		local delay = index * 0.04
		task.spawn(function()
			task.wait(delay + 0.12)
			local targetScale = (sliderValue - sliderMin) / (sliderMax - sliderMin)
			local overshoot = math.min(targetScale + 0.08, 1)
			TweenService:Create(sliderDrag, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.fromScale(overshoot, 1)
			}):Play()
			task.wait(0.35)
			TweenService:Create(sliderDrag, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.fromScale(targetScale, 1)
			}):Play()
			task.spawn(function()
				local sweep = Instance.new("Frame")
				sweep.Size = UDim2.new(0, 4, 1, 0)
				sweep.Position = UDim2.new(0, 0, 0, 0)
				sweep.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				sweep.BackgroundTransparency = 0.5
				sweep.BorderSizePixel = 0
				sweep.ZIndex = sliderDrag.ZIndex + 3
				sweep.Parent = sliderDrag
				TweenService:Create(sweep, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Position = UDim2.new(1, 0, 0, 0),
					BackgroundTransparency = 1
				}):Play()
				task.wait(0.45)
				sweep:Destroy()
			end)
		end)
	end

