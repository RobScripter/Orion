	local function AnimateElementIntro(frame, elementType)
		_introIndex = _introIndex + 1
		_lastElementTime = tick()
		if _isLoading then
			-- Pendant le loading: cacher l'element, mettre en queue
			frame.Visible = false
			table.insert(_animQueue, {type = "element", frame = frame, elementType = elementType, index = _introIndex})
		else
			_PlayElementAnim(frame, elementType, _introIndex)
		end
	end

