				OrionLib:_SmartDefault(SliderConfig, "Default", 50, "number", "AddSlider")
				OrionLib:_SmartDefault(SliderConfig, "Callback", function() end, "function", "AddSlider")
				OrionLib:_SmartDefault(SliderConfig, "ValueName", "", "string", "AddSlider")
				OrionLib:_SmartDefault(SliderConfig, "Color", Color3.fromRGB(9, 149, 98), "Color3", "AddSlider")
				if SliderConfig.Flag == nil then
					SliderConfig.Flag = nil
				end
				OrionLib:_SmartDefault(SliderConfig, "Save", false, "boolean", "AddSlider")

				if SliderConfig.Max < SliderConfig.Min then
					OrionLib:LogDebug("warn", "AddSlider", "Min et Max etaient inverses, Orion les a corriges automatiquement.")
					SliderConfig.Min, SliderConfig.Max = SliderConfig.Max, SliderConfig.Min
				end

				if SliderConfig.Increment <= 0 then
					OrionLib:LogDebug("warn", "AddSlider", "Increment invalide detecte, Orion l'a remplace par 1.")
					SliderConfig.Increment = 1
				end

				local DefaultValue = math.clamp(Round(SliderConfig.Default, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
				local Slider = {Value = DefaultValue, Save = SliderConfig.Save, Type = "Slider"}
