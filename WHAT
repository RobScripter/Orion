						Scale.Parent = Item
					end

					Scale.Scale = 0.93
					Item.BackgroundTransparency = 1

					for _, desc in ipairs(Item:GetDescendants()) do
						if desc:IsA("TextLabel") then
							if not desc:GetAttribute("OrigTextTransparency") then
