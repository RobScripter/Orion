							end
							desc.Transparency = 1
						end
					end
				end

				for index, Item in ipairs(Items) do
					task.delay((index - 1) * 0.035, function()
						if CurrentNonce ~= _tabAnimNonce then
							return
						end
						if not Item or not Item.Parent or not Container.Visible then
							return
						end

						local Scale = Item:FindFirstChild("_TabScale")
