function OrionLib:MakeNotifi(Configs)
	Configs = Configs or {}

	return OrionLib:MakeNotification({
		Name = Configs.Title or Configs.Name or "Notification",
		Content = Configs.Text or Configs.Content or "Notification content...",
		Time = Configs.Time or 5,
		Image = Configs.Image or "rbxassetid://4384403532"
	})
end

function OrionLib:Destroy()
	-- DÃ©sactiver tous les toggles
	for _, Flag in pairs(OrionLib.Flags) do
		if Flag.Type == "Toggle" and Flag.Value == true then
			pcall(function() Flag:Set(false) end)
		end
	end
	-- DÃ©connecter toutes les connections
	for _, Connection in next, OrionLib.Connections do
		pcall(function() Connection:Disconnect() end)
	end
	OrionLib.Connections = {}
	OrionLib.Flags = {}
	Orion:Destroy()
end

return OrionLib
