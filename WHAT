function OrionLib:_DebugTypeName(Value)
	local ValueType = typeof(Value)
	if ValueType == "Instance" then
		return Value.ClassName
	elseif ValueType == "EnumItem" then
		return tostring(Value.EnumType) .. "." .. Value.Name
	end
	return ValueType
end

function OrionLib:_BuildDebugHint(Context, Message)
	local LowerContext = string.lower(tostring(Context or ""))
	local LowerMessage = string.lower(tostring(Message or ""))

	if string.find(LowerMessage, "attempt to index nil") then
		return "Un objet attendu est nil. Verifie WaitForChild(), les noms d'objets et les variables locales."
	elseif string.find(LowerMessage, "attempt to call a nil value") then
		return "Une fonction est nil. Verifie Callback = function() end, loadstring(...)() et les retours."
	elseif string.find(LowerMessage, "invalid argument") or string.find(LowerMessage, "unable to cast") then
		return "Un argument a le mauvais type. Verifie tes nombres, Color3, tables et KeyCode."
	elseif string.find(LowerMessage, "attempt to perform arithmetic") then
		return "Une operation numerique recoit nil ou du texte. Verifie Min, Max, Increment et Default."
	elseif string.find(LowerMessage, "table index is nil") or string.find(LowerMessage, "invalid table key") then
		return "Une cle de table est nil. Verifie Flag, Name et les index utilises."
	elseif string.find(LowerMessage, "attempt to concatenate") then
		return "Une valeur concatenee n'est pas du texte. Convertis-la avec tostring(...)."
	elseif string.find(LowerMessage, "color3") then
		return "Une couleur invalide a ete detectee. Utilise Color3.fromRGB(...) ou Color3.new(...)."
	elseif string.find(LowerMessage, "enum.keycode") or string.find(LowerMessage, "keycode") then
		return "Le bind attend un Enum.KeyCode valide ou un nom de touche reconnu."
	end

	if string.find(LowerContext, "slider") then
		return "Verifie Min < Max, Increment > 0 et Default dans la plage du slider."
	elseif string.find(LowerContext, "toggle") then
		return "Verifie que le callback du toggle supporte bien true/false."
	elseif string.find(LowerContext, "dropdown") then
		return "Verifie que Options est une table et que Default existe dedans."
	elseif string.find(LowerContext, "bind") then
		return "Verifie que Default est un Enum.KeyCode ou une touche connue."
	elseif string.find(LowerContext, "colorpicker") then
		return "Verifie que Default est un Color3 valide."
	end

	return nil
end

function OrionLib:_SmartDefault(Config, Key, DefaultValue, ExpectedType, Context)
	if Config[Key] == nil then
		Config[Key] = DefaultValue
		return Config[Key]
	end

	if ExpectedType and typeof(Config[Key]) ~= ExpectedType then
		self:LogDebug("warn", Context or "Config", string.format(
			"Config '%s' invalide: attendu %s, recu %s. Valeur remplacee.",
			tostring(Key),
			tostring(ExpectedType),
			self:_DebugTypeName(Config[Key])
		))
		Config[Key] = DefaultValue
	end

	return Config[Key]
end

function OrionLib:_SmartKeyCode(Value, Context)
	if Value == nil then
		return Enum.KeyCode.Unknown
	end

	if typeof(Value) == "EnumItem" then
		return Value
	end

	if typeof(Value) == "string" then
		for _, Item in ipairs(Enum.KeyCode:GetEnumItems()) do
			if Item.Name == Value or string.lower(Item.Name) == string.lower(Value) then
				return Item
			end
		end
	end

	self:LogDebug("warn", Context or "BindConfig", "Bind invalide detecte, Orion a remplace la touche par Unknown.")
	return Enum.KeyCode.Unknown
end

function OrionLib:LogDebug(Level, Context, Message)
	local State = self.DebugState
	local Entry = {
		Time = os.date("%H:%M:%S"),
		Level = tostring(Level or "info"),
		Context = tostring(Context or "Unknown"),
		Message = tostring(Message or "No message")
	}
	Entry.Hint = self:_BuildDebugHint(Entry.Context, Entry.Message)

	table.insert(State.Logs, 1, Entry)
	while #State.Logs > State.MaxLogs do
		table.remove(State.Logs)
	end

	if not State.Enabled then
		return Entry
	end

	local Pretty = string.format("[Orion Debug][%s][%s] %s", Entry.Level:upper(), Entry.Context, Entry.Message)
	if Entry.Hint then
		Pretty = Pretty .. " | Hint: " .. Entry.Hint
	end

	if State.Print then
		warn(Pretty)
	end

	if State.Notifications and self.MakeNotification and self:IsRunning() then
		local Key = Entry.Context .. "::" .. Entry.Message
		local LastTick = State.RepeatMap[Key] or 0

		if tick() - LastTick >= State.RepeatWindow then
			State.RepeatMap[Key] = tick()
			task.spawn(function()
				pcall(function()
					self:MakeNotification({
						Name = "Orion Debug",
						Content = string.sub(Entry.Context .. " -> " .. (Entry.Hint or Entry.Message), 1, 160),
						Time = 6,
						Image = "alert-triangle"
					})
				end)
			end)
		end
	end

	return Entry
end

function OrionLib:_SafeCall(Context, Callback, ...)
	if typeof(Callback) ~= "function" then
		return true
	end

	local Args = table.pack(...)
	local Results

	local SuccessCall, ErrorOrNil = xpcall(function()
		Results = table.pack(Callback(table.unpack(Args, 1, Args.n)))
	end, function(ErrorMessage)
		if debug and debug.traceback then
			return debug.traceback(tostring(ErrorMessage), 2)
		end
		return tostring(ErrorMessage)
	end)

	if not SuccessCall then
		self:LogDebug("error", Context, ErrorOrNil)
		return false
	end

	if Results then
		return true, table.unpack(Results, 1, Results.n)
	end

	return true
end

local function AddConnection(Signal, Function, Context)
	if (not OrionLib:IsRunning()) then
		return
	end
	local SignalConnect = Signal:Connect(function(...)
		OrionLib:_SafeCall(Context or "SignalConnection", Function, ...)
	end)
	table.insert(OrionLib.Connections, SignalConnect)
	return SignalConnect
end

