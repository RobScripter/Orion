				function Slider:Set(Value)
					local NewValue = math.clamp(Round(Value, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
					local Changed = NewValue ~= self.Value
					self.Value = NewValue

					local Scale = GetScale(self.Value)
					local DisplayValue = FormatValue(self.Value)
					local FillTarget = UDim2.fromScale(Scale, 1)
					local KnobTarget = UDim2.new(Scale, 0, 0.5, 0)
					local TweenTime = Dragging and 0.08 or 0.18

					TweenService:Create(SliderFill, TweenInfo.new(TweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
						Size = FillTarget
					}):Play()
					TweenService:Create(SliderKnob, TweenInfo.new(TweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
						Position = KnobTarget
					}):Play()

					SliderFrame.CurrentValue.Text = DisplayValue
					SliderBar.Value.Text = DisplayValue
					SliderFill.Value.Text = Scale > 0.18 and DisplayValue or ""

					if Changed then
						if not Dragging then
							PlaySliderBurst()
						end
						task.spawn(function()
							OrionLib:_SafeCall("Slider:" .. SliderConfig.Name, SliderConfig.Callback, self.Value)
						end)
					end
				end

