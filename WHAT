function OrionLib:Debug(Config)
	Config = Config or {}

	if Config.Enabled ~= nil then
		self.DebugState.Enabled = Config.Enabled
	end
	if Config.Notifications ~= nil then
		self.DebugState.Notifications = Config.Notifications
	end
	if Config.Print ~= nil then
		self.DebugState.Print = Config.Print
	end
	if Config.MaxLogs ~= nil then
		self.DebugState.MaxLogs = math.max(10, Config.MaxLogs)
	end
	if Config.RepeatWindow ~= nil then
		self.DebugState.RepeatWindow = math.max(0, Config.RepeatWindow)
	end

	return self.DebugState
end

function OrionLib:GetDebugLogs()
	local Copy = {}
	for Index, Entry in ipairs(self.DebugState.Logs) do
		Copy[Index] = Entry
	end
	return Copy
end

function OrionLib:GetLastDebugIssue()
