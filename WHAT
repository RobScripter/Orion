	local function _PlaySliderAnim(sliderDrag, sliderValue, sliderMin, sliderMax, index)
		sliderDrag.Size = UDim2.new(0, 0, 1, 0)
		local sliderKnob = sliderDrag.Parent and sliderDrag.Parent:FindFirstChild("Knob")
		local knobFinalSize = sliderKnob and sliderKnob.Size
		if sliderKnob then
			sliderKnob.Size = UDim2.new(0, 0, 0, 0)
			sliderKnob.Position = UDim2.new(0, 0, 0.5, 0)
		end
		local delay = index * 0.04
		task.spawn(function()
			task.wait(delay + 0.12)
			local range = sliderMax - sliderMin
			local targetScale = range == 0 and 0 or ((sliderValue - sliderMin) / range)
			targetScale = math.clamp(targetScale, 0, 1)
			local overshoot = math.min(targetScale + 0.08, 1)
			TweenService:Create(sliderDrag, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.fromScale(overshoot, 1)
			}):Play()
			if sliderKnob then
				TweenService:Create(sliderKnob, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Size = UDim2.new(0, 20, 0, 20),
					Position = UDim2.new(overshoot, 0, 0.5, 0)
				}):Play()
			end
			task.wait(0.35)
			TweenService:Create(sliderDrag, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.fromScale(targetScale, 1)
			}):Play()
			if sliderKnob then
				TweenService:Create(sliderKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Size = knobFinalSize or UDim2.new(0, 16, 0, 16),
					Position = UDim2.new(targetScale, 0, 0.5, 0)
				}):Play()
			end
			task.spawn(function()
				local sweep = Instance.new("Frame")
				sweep.Size = UDim2.new(0, 4, 1, 0)
				sweep.Position = UDim2.new(0, 0, 0, 0)
				sweep.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				sweep.BackgroundTransparency = 0.5
				sweep.BorderSizePixel = 0
				sweep.ZIndex = sliderDrag.ZIndex + 3
				sweep.Parent = sliderDrag
				TweenService:Create(sweep, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Position = UDim2.new(1, 0, 0, 0),
					BackgroundTransparency = 1
				}):Play()
				task.wait(0.45)
				sweep:Destroy()
			end)
		end)
	end

